# Server Configuration
PORT=5000
NODE_ENV=development

# Performance Monitoring Configuration
REACT_APP_PERFORMANCE_SAMPLE_RATE=1.0
REACT_APP_PERFORMANCE_SLOW_THRESHOLD=16
REACT_APP_PERFORMANCE_MAX_METRICS=1000
REACT_APP_PERFORMANCE_ENABLE_MEMORY_TRACKING=true
REACT_APP_PERFORMANCE_ENABLE_INTERACTION_TRACKING=true

# API Configuration
REACT_APP_API_BASE_URL=/api
REACT_APP_API_TIMEOUT=5000
REACT_APP_API_KEY=test-api-key
ALLOWED_ORIGINS=http://localhost:3000

# Logging Configuration
REACT_APP_LOG_LEVEL=debug
REACT_APP_ENABLE_PERFORMANCE_LOGGING=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_CLUSTER_ENABLED=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Monitoring Configuration
PROMETHEUS_METRICS_PATH=/api/performance/metrics/prometheus
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Add your GitHub personal access token here for testing
# GITHUB_TOKEN=your_personal_access_token 